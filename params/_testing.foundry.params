#!/bin/bash
# 1. Load the Base Forge Specs (The Parent)
source "$(dirname "${BASH_SOURCE[0]}")/foundry.params"

# 2. Apply Testing Overwrites (The Child)
# This replaces whatever HOST_OUTPUT_DIR was set in the main file.
HOST_OUTPUT_DIR="/mnt/build-data/dist/testing"
echo "🧪 Testing Profile Loaded: Diverting output to $HOST_OUTPUT_DIR"