# ==============================================================================
# HARPER FOUNDRY: UNIFIED PERFORMANCE TUNING (v4.0 Final)
# Targeting: Ryzen 5800X3D + 7900 GRE | i7-12700H + RTX A2000
# Base: Debian 6.18.5-64bit (Clang/LLVM 19)
# ==============================================================================

# --- Modern x86-64-v3 Architecture Optimization ---
# Disabling the generic 2004-era baseline and vendor-specific locks
# CONFIG_GENERIC_CPU is not set
# CONFIG_MZEN3 is not set
CONFIG_GENERIC_CPU_V3=y

# --- Windows / Proton Fast Synchronization (ntsync) ---
# Direct support for WINE_NTSYNC=1 global environment variable
CONFIG_NTSYNC=y
CONFIG_WINESYNC=y

# --- CPU Scheduler & Preemption (KDE/Gaming Responsiveness) ---
# Burst-Oriented Response Enhancer (BORE) and Full Preemption
CONFIG_SCHED_BORE=y
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set
CONFIG_PREEMPT=y
CONFIG_PREEMPT_BUILD=y

# --- Internal Timer Frequency (1000Hz Desktop Latency) ---
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
# CONFIG_HZ_500 is not set
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# --- Silicon-Level Power Management & Core Topology ---
# Microsecond clock scaling and Alder Lake P/E core awareness
CONFIG_X86_INTEL_PSTATE=y
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_DEFAULT_MODE=3
CONFIG_SCHED_MC=y
CONFIG_SCHED_MC_PRIO=y
CONFIG_SCHED_CLUSTER=y
CONFIG_SCHED_SMT=y

# --- Software Frequency Scaling Fallback ---
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# --- Fast Boot & Rapid Wake (ZSTD Compression) ---
# Blistering decompression speeds for kernel and loadable modules
# CONFIG_KERNEL_GZIP is not set
# CONFIG_KERNEL_XZ is not set
CONFIG_KERNEL_ZSTD=y
# CONFIG_MODULE_COMPRESS_XZ is not set
CONFIG_MODULE_COMPRESS_ZSTD=y

# --- Memory Management (ZSWAP, LRU, Hugepages) ---
# Prevents desktop "freeze" during heavy compilation or low-RAM events
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_USERFAULTFD=y

# --- Hardware Precision & Gaming Performance ---
# Smart Access Memory support and split-lock stutter fixes
# CONFIG_X86_SPLIT_LOCK_MITIGATION is not set
CONFIG_PCI_REALLOC_ENABLE_AUTO=y
CONFIG_BLK_WBT=y
CONFIG_BLK_WBT_MQ=y

# --- Network Congestion Control (Low Latency Gaming) ---
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# --- Compiler Safety & Clang/LLVM Integration ---
# Preventing AMD driver crashes and ensuring clean linking
CONFIG_CC_IS_CLANG=y
# CONFIG_WERROR is not set
CONFIG_FRAME_WARN=4096
CONFIG_LTO_NONE=y
# CONFIG_LTO_CLANG_THIN is not set
# CONFIG_CFI_CLANG is not set

# Disable all debug symbol generation
CONFIG_DEBUG_INFO_NONE=y

# Explicitly unset the other common debug formats
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT is not set
# CONFIG_DEBUG_INFO_DWARF4 is not set
# CONFIG_DEBUG_INFO_DWARF5 is not set