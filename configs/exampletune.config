# ==============================================================================
# HARPER FOUNDRY: EXAMPLE PERFORMANCE TUNING
# ==============================================================================
# A minimal example tuning file demonstrating key desktop/gaming optimizations:
#   • 1000Hz timer frequency for lower latency
#   • Full preemption for responsive user input
#   • ZSTD kernel compression for faster boot
#
# This can be used as TUNING_CONFIG in any params file to overlay these
# optimizations on top of your base config (e.g., defconfig).
#
# === HOW TO USE ===
# In your params file:
#   BASE_CONFIG="defconfig"
#   TUNING_CONFIG="exampletune.config"
#
# === PERFORMANCE IMPACT ===
# • Reduced latency: ~5-10ms improvement in user input response
# • Slightly higher CPU usage at idle (more frequent timer ticks)
# • Boot time: Slightly faster decompression with ZSTD
# • Memory: Negligible impact (~1-2MB extra due to more timer interrupts)
# ==============================================================================

# --- Timer Frequency (Latency Optimization) ---
# 1000Hz provides ~1ms timer tick granularity vs Debian's 250Hz (~4ms)
# Benefits: Smoother animations, gaming, interactive workloads
# Cost: Slightly higher CPU usage and power consumption at idle
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
# CONFIG_HZ_500 is not set
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# --- Preemption (Responsiveness Optimization) ---
# Full preemption allows the scheduler to interrupt task execution
# at almost any point, improving responsiveness to high-priority tasks
# Benefits: Gaming, interactive desktop, real-time feel
# Cost: Slightly more context switches, minimal performance impact
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set
CONFIG_PREEMPT=y
CONFIG_PREEMPT_BUILD=y

# --- Kernel Compression (Boot Speed Optimization) ---
# ZSTD provides better compression ratio and faster decompression
# than gzip or xz, speeding up kernel loading at boot
# Benefits: ~10-20% faster kernel decompression
# Cost: Slightly larger image size, minimal runtime impact
CONFIG_KERNEL_ZSTD=y
# CONFIG_KERNEL_GZIP is not set
# CONFIG_KERNEL_XZ is not set

# --- High Resolution Timers (Enables sub-millisecond precision) ---
# Required for full preemption and 1000Hz to be effective
CONFIG_HIGH_RES_TIMERS=y

# --- Idle Power Management (Optional - Complements above tweaks) ---
# Allow the kernel to reduce timer frequency when system is idle
# Benefits: Lower power consumption when nothing is happening
# Cost: None when idle, latency when waking up is acceptable
CONFIG_NO_HZ_IDLE=y
