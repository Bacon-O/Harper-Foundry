# ==============================================================================
# HARPER FOUNDRY: OPTIMIZED TUNING INJECTION
# Target: x86-64-v3 + BORE + 500Hz + NTSYNC
# ==============================================================================

# --- 1. The Heartbeat (Scheduling & Timers) ---
# Setting the "Golden Middle" 500Hz tick rate
CONFIG_HZ_500=y
CONFIG_HZ=500
CONFIG_SCHED_BORE=y
CONFIG_NO_HZ_IDLE=y
CONFIG_CONTEXT_TRACKING_GUESS=y

# --- 2. Preemption (The "Snappiness" Factor) ---
# We use PREEMPT (Dynamic) instead of PREEMPT_RT to avoid driver conflicts
CONFIG_PREEMPT_BUILD=y
CONFIG_PREEMPT=y
CONFIG_PREEMPT_COUNT=y
CONFIG_PREEMPTION=y

# --- 3. Windows Sync (NTSYNC Support) ---
# Essential for WINE_NTSYNC=1 to function
CONFIG_NTSYNC=y
CONFIG_MISC_DEVICES=y
CONFIG_FUTEX=y
CONFIG_FUTEX_PI=y

# --- 4. CPU Optimization (x86-64-v3 focus) ---
# Disabling generic to allow march=x86-64-v3 flags to be more effective
CONFIG_GENERIC_CPU=n
CONFIG_MCORE2=y
CONFIG_X86_64_ABI_V3=y

# --- 5. Performance Tweaks ---
# Reducing overhead for gaming workloads
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=n
CONFIG_ENERGY_MODEL=n
CONFIG_SCHED_AUTOGROUP=y
CONFIG_SCHED_HRTICK=y

# --- 6. Security & Cleanup (Foundry Standards) ---
# Disabling debug overhead that slows down custom kernels
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_KERNEL=n
CONFIG_STACK_VALIDATION=n