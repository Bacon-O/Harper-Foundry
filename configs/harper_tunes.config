# ==============================================================================
# HARPER FOUNDRY: TINYCONFIG INJECTION (x86-64-v3 + NTSYNC)
# ==============================================================================

# --- 1. Infrastructure & Plumbing (CRITICAL) ---
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_PCI=y
CONFIG_EXPERT=y
CONFIG_POSIX_TIMERS=y
CONFIG_MISC_DEVICES=y   # <--- The Gatekeeper for NTSYNC
CONFIG_HAS_IOMEM=y      # <--- Required for hardware mapping

# Essential Kernel Internals for Synchronization Primitives
CONFIG_FUTEX=y
CONFIG_EVENTFD=y
CONFIG_EPOLL=y
CONFIG_FILE_LOCKING=y
CONFIG_ANON_INODES=y

# --- 2. CPU Strategy (v3 Optimization) ---
# We disable Generic to allow your KCFLAGS="-march=x86-64-v3" to take over.
CONFIG_GENERIC_CPU=n
CONFIG_MCORE2=y

# --- 3. The Features (Audit Targets) ---
# You MUST enable the driver (NTSYNC) for the interface (WINE_NTSYNC) to exist.
CONFIG_NTSYNC=y         # <--- MISSING IN YOUR SNIPPET
CONFIG_WINE_NTSYNC=y
CONFIG_PREEMPT_RT=y

# --- 4. The Voice (QEMU Serial Support) ---
# Allows you to see boot logs if you ever enable QEMU testing.
CONFIG_TTY=y
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4

# --- 3. CPU Scheduler (The "BORE" Identity) ---
# Burst-Oriented Response Enhancer
CONFIG_SCHED_BORE=y