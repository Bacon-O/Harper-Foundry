# === HARPER-KERNEL 5800X3D TUNING ===

# 1. CPU Identity & SMP
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_MZEN3=y
CONFIG_ZEN3=y
CONFIG_X86_64_SMP=y
CONFIG_SCHED_OMIT_FRAME_POINTER=y

# 2. Real-Time & Wine Performance
CONFIG_EXPERT=y
CONFIG_PREEMPT_RT=y
CONFIG_PREEMPT_COUNT=y
CONFIG_POSIX_TIMERS=y
CONFIG_WINE_NTSYNC=y
CONFIG_MISC_DEVICES=y

# 3. Essential Infrastructure (Debian & Boot)
CONFIG_NET=y
CONFIG_BLOCK=y
CONFIG_BINFMT_ELF=y
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
CONFIG_PCI=y

# 4. The Voice (QEMU / Serial Console)
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4