# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 4

# Bash-specific files
[{*.bash,*.zsh}]
indent_size = 4

# Dockerfiles
[{Dockerfile,*.dockerfile}]
indent_size = 4

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Config files
[*.config]
indent_size = 4

# Params files
[*.params]
indent_size = 4
